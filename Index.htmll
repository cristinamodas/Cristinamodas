<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cristina Modas</title>
    <link rel="stylesheet" href="assets/style.css">
</head>
<body>
    <header>
        <h1>Cristina Modas</h1>
        <nav>
            <button class="categoria-btn ativo" data-categoria="todos">Todos</button>
            <button class="categoria-btn" data-categoria="Feminino">Feminino</button>
            <button class="categoria-btn" data-categoria="Masculino">Masculino</button>
            <button class="categoria-btn" data-categoria="Acessórios">Acessórios</button>
        </nav>
    </header>

    <main>
        <div class="produtos-grid" id="produtos-container"></div>
    </main>

    <footer>
        <p>© 2026 Cristina Modas</p>
    </footer>

    <script src="assets/script.js"></script>
</body>
</html>
